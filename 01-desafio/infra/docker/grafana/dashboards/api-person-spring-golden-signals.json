          "expr": "sum(hikaricp_connections_idle{service_name=\"$service\", pool=~\".*reader.*\"}) by (pool)",
          "legendFormat": "idle"
        },
        {
          "expr": "sum(hikaricp_connections_pending{service_name=\"$service\", pool=~\".*reader.*\"}) by (pool)",
          "legendFormat": "pending"
        },
        {
          "expr": "sum(hikaricp_connections_max{service_name=\"$service\", pool=~\".*reader.*\"}) by (pool)",
          "legendFormat": "max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "max" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pending" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
