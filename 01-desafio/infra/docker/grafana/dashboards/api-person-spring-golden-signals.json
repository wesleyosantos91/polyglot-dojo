      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=\"$service\"}[$__rate_interval])) by (http_request_method, url_template)",
          "legendFormat": "{{http_request_method}} {{url_template}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8
