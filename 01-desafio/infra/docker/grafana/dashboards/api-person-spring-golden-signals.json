              { "color": "green", "value": null },
              { "color": "yellow", "value": 200 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "desc" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
