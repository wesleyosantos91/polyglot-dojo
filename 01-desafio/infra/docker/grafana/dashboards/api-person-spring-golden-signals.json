    {
      "id": 20,
      "type": "timeseries",
      "title": "CPU & Heap Usage (%)",
      "description": "Uso de CPU (processo e sistema) e percentual de heap utilizado em relação ao máximo.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "process_cpu_usage{service_name=\"$service\"} * 100",
          "legendFormat": "Process CPU %"
        },
        {
          "expr": "system_cpu_usage{service_name=\"$service\"} * 100",
          "legendFormat": "System CPU %"
        },
        {
          "expr": "100 * sum(jvm_memory_used_bytes{service_name=\"$service\", area=\"heap\"}) / clamp_min(sum(jvm_memory_max_bytes{service_name=\"$service\", area=\"heap\"}), 1)",
          "legendFormat": "Heap Used %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Process CPU %" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Heap Used %" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 107,
      "type": "timeseries",
      "title": "GC Pause Time & Count",
      "description": "Tempo e contagem de pausas do Garbage Collector. Pausas frequentes ou longas indicam pressão de memória.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(jvm_gc_pause_seconds_sum{service_name=\"$service\"}[$__rate_interval])) by (cause) * 1000",
          "legendFormat": "GC time (ms/s) — {{cause}}"
        },
        {
          "expr": "sum(rate(jvm_gc_pause_seconds_count{service_name=\"$service\"}[$__rate_interval])) by (cause)",
          "legendFormat": "GC count/s — {{cause}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 400,
      "type": "row",
      "title": "🛡️ Resiliência & Business Errors",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "collapsed": false
    },
    {
      "id": 12,
      "type": "stat",
      "title": "DB Retry Exhausted / min",
      "description": "Chamadas onde todas as tentativas de retry de banco foram esgotadas. Indica falhas persistentes de BD.",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(db_retry_exhausted_total{service_name=\"$service\"}[5m])) * 60",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
