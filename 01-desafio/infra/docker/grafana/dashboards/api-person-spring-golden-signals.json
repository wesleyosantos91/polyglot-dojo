              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background_solid",
        "graphMode": "none",
        "justifyMode": "center"
