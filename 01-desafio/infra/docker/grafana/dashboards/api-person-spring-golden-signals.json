      "id": 14,
      "type": "stat",
      "title": "Slow Requests Rate (%)",
      "description": "Percentual de requisições classificadas como lentas (acima do threshold configurado na aplicação).",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "100 * sum(rate(http_access_events_total{service_name=\"$service\",outcome=\"SLOW\"}[5m])) / clamp_min(sum(rate(http_access_events_total{service_name=\"$service\"}[5m])),0.001)",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
