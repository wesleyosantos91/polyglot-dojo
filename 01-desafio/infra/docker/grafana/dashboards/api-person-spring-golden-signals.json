      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "DB Retry Next Delay Avg (ms)",
      "description": "Delay médio entre tentativas de retry de banco. Valores crescentes indicam backoff exponencial.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "1000 * sum(rate(db_retry_next_delay_sum{service_name=\"$service\"}[$__rate_interval])) / clamp_min(sum(rate(db_retry_next_delay_count{service_name=\"$service\"}[$__rate_interval])), 0.001)",
          "legendFormat": "avg next delay"
