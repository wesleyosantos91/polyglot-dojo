{
  "uid": "api-person-spring-jvm-infra",
  "title": "API Person Spring — JVM & Infrastructure",
  "description": "Monitoramento detalhado de JVM (memória, GC, threads, class loading) e infraestrutura do container",
  "tags": [
    "api-person-spring",
    "jvm",
    "infrastructure",
    "memory",
    "gc",
    "threads"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "graphTooltip": 2,
  "editable": true,
  "fiscalYearStartMonth": 0,
  "links": [
    {
      "asDropdown": false,
      "icon": "grafana",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "Golden Signals",
      "type": "link",
      "url": "/d/api-person-spring-golden-signals"
    },
    {
      "asDropdown": false,
      "icon": "bolt",
      "includeVars": true,
      "keepTime": true,
      "tags": [],
      "targetBlank": false,
      "title": "Troubleshooting & RCA",
      "type": "link",
      "url": "/d/api-person-spring-troubleshooting"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": {
          "selected": true,
          "text": "api-person-spring",
          "value": "api-person-spring"
        },
        "hide": 0,
        "includeAll": false,
        "label": "Service",
        "multi": false,
        "name": "service",
        "options": [],
        "query": {
          "qryType": 1,
          "query": "label_values(jvm_memory_used_bytes, service_name)",
          "refId": "ServiceVariableQuery"
        },
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "📊 Visão Geral JVM",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Uptime",
      "description": "Tempo desde o último restart da JVM.",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "process_uptime_seconds{service_name=\"$service\"}",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null },
              { "color": "green", "value": 300 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background_solid",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Heap Used",
      "description": "Memória heap atualmente em uso pela JVM.",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{service_name=\"$service\", area=\"heap\"})",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 268435456 },
              { "color": "red", "value": 536870912 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Non-Heap Used",
      "description": "Memória non-heap (Metaspace, Code Cache, Compressed Class Space).",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{service_name=\"$service\", area=\"nonheap\"})",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 134217728 },
              { "color": "red", "value": 268435456 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Live Threads",
      "description": "Threads ativas na JVM (incluindo virtual threads se habilitado).",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{service_name=\"$service\"}",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 300 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Process CPU %",
      "description": "Uso de CPU pelo processo da JVM.",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "process_cpu_usage{service_name=\"$service\"} * 100",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 75 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Loaded Classes",
      "description": "Total de classes carregadas na JVM.",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jvm_classes_loaded_classes{service_name=\"$service\"}",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background_solid",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 200,
      "type": "row",
      "title": "🧠 Memória — Heap & Non-Heap",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Heap Memory by Pool",
      "description": "Uso de memória heap por pool (Eden, Survivor, Old Gen). Monitora pressão de GC.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{service_name=\"$service\", area=\"heap\"}",
          "legendFormat": "used — {{id}}"
        },
        {
          "expr": "jvm_memory_committed_bytes{service_name=\"$service\", area=\"heap\"}",
          "legendFormat": "committed — {{id}}"
        },
        {
          "expr": "jvm_memory_max_bytes{service_name=\"$service\", area=\"heap\"} > 0",
          "legendFormat": "max — {{id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "max.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "committed.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dot" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Non-Heap Memory by Pool",
      "description": "Uso de memória non-heap: Metaspace, Code Cache, Compressed Class Space.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{service_name=\"$service\", area=\"nonheap\"}",
          "legendFormat": "used — {{id}}"
        },
        {
          "expr": "jvm_memory_committed_bytes{service_name=\"$service\", area=\"nonheap\"}",
          "legendFormat": "committed — {{id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "committed.*" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dot" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Heap Usage % Over Time",
      "description": "Percentual de heap utilizado. Tendência crescente sem queda indica possível memory leak.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "100 * sum(jvm_memory_used_bytes{service_name=\"$service\", area=\"heap\"}) / clamp_min(sum(jvm_memory_max_bytes{service_name=\"$service\", area=\"heap\"}), 1)",
          "legendFormat": "Heap Used %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "thresholdsStyle": { "mode": "area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "orange", "value": 85 },
              { "color": "red", "value": 95 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "JVM Buffer Pools",
      "description": "Uso de buffer pools (direct, mapped). Importante para NIO e operações de I/O.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jvm_buffer_memory_used_bytes{service_name=\"$service\"}",
          "legendFormat": "used — {{id}}"
        },
        {
          "expr": "jvm_buffer_total_capacity_bytes{service_name=\"$service\"}",
          "legendFormat": "capacity — {{id}}"
        },
        {
          "expr": "jvm_buffer_count_buffers{service_name=\"$service\"}",
          "legendFormat": "count — {{id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "count.*" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "short" }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "(used|capacity).*" },
            "properties": [
              { "id": "unit", "value": "bytes" }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "♻️ Garbage Collection",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "GC Pause Duration (ms/s)",
      "description": "Tempo total gasto em pausas de GC por segundo, agrupado por causa. Valores altos = STW (stop-the-world) significativo.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(jvm_gc_pause_seconds_sum{service_name=\"$service\"}[$__rate_interval])) by (action, cause) * 1000",
          "legendFormat": "{{action}} — {{cause}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "GC Pause Count (/s)",
      "description": "Número de pausas de GC por segundo. Frequência alta com pausas curtas é esperado em ZGC.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(jvm_gc_pause_seconds_count{service_name=\"$service\"}[$__rate_interval])) by (action, cause)",
          "legendFormat": "{{action}} — {{cause}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 22,
      "type": "stat",
      "title": "GC Overhead (%)",
      "description": "Percentual de tempo gasto em GC (nos últimos 5 minutos). > 5% é preocupante.",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "100 * sum(rate(jvm_gc_pause_seconds_sum{service_name=\"$service\"}[5m]))",
          "instant": true,
          "legendFormat": ""
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "center"
      }
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Memory Allocation Rate (bytes/s)",
      "description": "Taxa de alocação de memória. Picos indicam criação intensiva de objetos.",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "sum(rate(jvm_gc_memory_allocated_bytes_total{service_name=\"$service\"}[$__rate_interval]))",
          "legendFormat": "allocation rate"
        },
        {
          "expr": "sum(rate(jvm_gc_memory_promoted_bytes_total{service_name=\"$service\"}[$__rate_interval]))",
          "legendFormat": "promotion rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "allocation rate" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "promotion rate" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 400,
      "type": "row",
      "title": "🧵 Threads",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 39 },
      "collapsed": false
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Thread Count",
      "description": "Contagem de threads: live, daemon e peak. Virtual Threads (JEP 444) estão habilitados neste projeto.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{service_name=\"$service\"}",
          "legendFormat": "live"
        },
        {
          "expr": "jvm_threads_daemon_threads{service_name=\"$service\"}",
          "legendFormat": "daemon"
        },
        {
          "expr": "jvm_threads_peak_threads{service_name=\"$service\"}",
          "legendFormat": "peak"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "peak" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Thread States",
      "description": "Threads por estado: RUNNABLE, WAITING, TIMED_WAITING, BLOCKED. BLOCKED alto indica contenção.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jvm_threads_states_threads{service_name=\"$service\"}",
          "legendFormat": "{{state}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth",
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "runnable" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "blocked" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "waiting" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "timed-waiting" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 500,
      "type": "row",
      "title": "⚙️ CPU & Sistema",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 },
      "collapsed": false
    },
    {
      "id": 40,
      "type": "timeseries",
      "title": "CPU Usage — Process vs System",
      "description": "Comparação entre uso de CPU do processo Java e uso total do sistema.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 49 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "process_cpu_usage{service_name=\"$service\"} * 100",
          "legendFormat": "Process CPU %"
        },
        {
          "expr": "system_cpu_usage{service_name=\"$service\"} * 100",
          "legendFormat": "System CPU %"
        },
        {
          "expr": "system_cpu_count{service_name=\"$service\"}",
          "legendFormat": "Available CPUs"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Available CPUs" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "short" },
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 41,
      "type": "timeseries",
      "title": "Class Loading",
      "description": "Classes carregadas e descarregadas ao longo do tempo. Crescimento constante pode indicar class loader leak.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 49 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jvm_classes_loaded_classes{service_name=\"$service\"}",
          "legendFormat": "loaded"
        },
        {
          "expr": "jvm_classes_unloaded_classes_total{service_name=\"$service\"}",
          "legendFormat": "unloaded (total)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "loaded" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 42,
      "type": "timeseries",
      "title": "File Descriptors",
      "description": "Uso de file descriptors abertos vs máximo permitido pelo SO. Esgotar este limite causa erro de I/O.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 57 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "process_files_open_files{service_name=\"$service\"}",
          "legendFormat": "open"
        },
        {
          "expr": "process_files_max_files{service_name=\"$service\"}",
          "legendFormat": "max"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "max" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    },
    {
      "id": 43,
      "type": "timeseries",
      "title": "Person Service Operation Latency (ms)",
      "description": "Latência das operações de negócio (person_service_operation), medida na camada de serviço.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 57 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(person_service_operation_seconds_bucket{service_name=\"$service\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(person_service_operation_seconds_bucket{service_name=\"$service\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(person_service_operation_seconds_bucket{service_name=\"$service\"}[$__rate_interval])) by (le)) * 1000",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "scheme",
            "spanNulls": true,
            "showPoints": "never",
            "lineInterpolation": "smooth"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max", "lastNotNull"]
        }
      }
    }
  ]
